# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
SESSION_EXPIRE_MINUTES=10080

# PostgreSQL (e.g. Neon)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gms_world_foods
DB_USER=postgres
DB_PASSWORD=
DB_SSL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=GMS_WORLD_FOODS
CLOUDINARY_FOLDER=gms-world-foods

# Comma-separated origins (add your Netlify/production URL here)
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
